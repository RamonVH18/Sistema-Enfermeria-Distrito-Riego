<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextArea?>
<?import javafx.geometry.Insets?>

<VBox fx:id="formContainer" spacing="15" prefWidth="500" styleClass="form-card" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controladores.AgendarCitaController">
    <padding>
        <Insets top="30" right="40" bottom="30" left="40" />
    </padding>

    <Label text="Agendar Nueva Cita" styleClass="form-title" alignment="CENTER" maxWidth="Infinity" />

    <VBox spacing="5">
        <Label text="Nombre del Paciente" styleClass="form-label" />
        <ComboBox fx:id="cbPaciente" editable="true" maxWidth="Infinity" />
    </VBox>

    <VBox spacing="5">
        <Label text="ID del Empleado" styleClass="form-label"  />
        <TextField fx:id="txtIdEmpleado" promptText="00000XXXXX" editable="false"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Fecha" styleClass="form-label" />
        <DatePicker fx:id="dpFechaCita" maxWidth="Infinity" />
    </VBox>

    <VBox spacing="5">
        <Label text="Hora" styleClass="form-label" />
        <ComboBox fx:id="cbHora" maxWidth="Infinity" promptText="Seleccione hora" />
    </VBox>

    <VBox spacing="5">
        <Label text="Descripción de la cita" styleClass="form-label" />
        <TextArea fx:id="txtDescripcion" prefHeight="100" wrapText="true" promptText="ej. Chequeo Rutinario" />
    </VBox>

    <HBox spacing="20" alignment="CENTER">
        <Button text="Cancelar" fx:id="btnCancelar" styleClass="btn-cancel" />
        <Button text="Agendar Cita" fx:id="btnAgendar" styleClass="btn-submit" />
    </HBox>
</VBox>