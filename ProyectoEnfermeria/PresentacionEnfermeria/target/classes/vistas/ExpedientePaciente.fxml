<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="800.0" prefWidth="900.0" spacing="20.0" styleClass="root" 
      stylesheets="@HistorialMedico.css" xmlns="http://javafx.com/javafx/17" 
      xmlns:fx="http://javafx.com/fxml/1">
    
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <!-- Encabezado Principal -->
    <VBox spacing="5.0">
        <Label styleClass="title-label" text="Historial Medico del Paciente" />
        <Label styleClass="subtitle-label" text="Registro clínicos completos y gestion de informacion de salud" />
    </VBox>

    
    <!-- Tarjeta de Información Personal -->
    <VBox spacing="15.0" styleClass="section-container">
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label style="-fx-font-size: 30px;" text="👤" />
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Mario Alfredo Jimenez Valencia" />
        </HBox>
        <HBox spacing="50.0">
            <Label text="ID: EMP-4245" />
            <Label text="Departamento: Manufactura" />
            <Label text="Edad: 34" />
            <Label text="Tipo de Sangre: A-" />
        </HBox>
    </VBox>

    <!-- Barra de Navegación -->
    <HBox alignment="CENTER" spacing="20.0" styleClass="tab-container">
        <Button prefWidth="150" styleClass="nav-button-active" text="Signos Vitales" />
        <Button prefWidth="150" styleClass="nav-button" text="Antecedentes Medicos" />
        <Button prefWidth="150" styleClass="nav-button" text="Sintomas y Diagnostico" />
        <Button prefWidth="150" styleClass="nav-button" text="Plan de Tratamiento" />
    </HBox>

    <!-- Sección de Signos Vitales -->
    <VBox spacing="30.0" styleClass="section-container">
        <Label styleClass="vital-label-header" text="Signos Vitales Actuales" />
        
        <GridPane hgap="40.0" vgap="30.0">
            <columnConstraints>
                <ColumnConstraints halignment="CENTER" percentWidth="33.3" />
                <ColumnConstraints halignment="CENTER" percentWidth="33.3" />
                <ColumnConstraints halignment="CENTER" percentWidth="33.3" />
            </columnConstraints>

            <!-- Fila 1 -->
            <VBox alignment="CENTER" spacing="5" GridPane.columnIndex="0">
                <Label styleClass="vital-value-name" text="Presion Arterial ( mmHg )" />
                <Label styleClass="vital-value-number" text="120/80" />
            </VBox>
            <VBox alignment="CENTER" spacing="5" GridPane.columnIndex="1">
                <Label styleClass="vital-value-name" text="Frecuencia Cardiaca (lpm)" />
                <Label styleClass="vital-value-number" text="72" />
            </VBox>
            <VBox alignment="CENTER" spacing="5" GridPane.columnIndex="2">
                <Label styleClass="vital-value-name" text="Temperatura ( Celcius )" />
                <Label styleClass="vital-value-number" text="36.5" />
            </VBox>

            <!-- Fila 2 -->
            <VBox alignment="CENTER" spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label styleClass="vital-value-name" text="Peso (kg)" />
                <Label styleClass="vital-value-number" text="68" />
            </VBox>
            <VBox alignment="CENTER" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label styleClass="vital-value-name" text="Altura (cm)" />
                <Label styleClass="vital-value-number" text="176" />
            </VBox>
            <VBox alignment="CENTER" spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="1">
                <Label styleClass="vital-value-name" text="Saturacion de Oxigeno (%)" />
                <Label styleClass="vital-value-number" text="98" />
            </VBox>
        </GridPane>

        <!-- Recuadro de IMC -->
        <VBox spacing="5.0" styleClass="imc-box">
            <Label style="-fx-font-weight: bold;" text="Calculo de IMC" />
            <Label styleClass="imc-value" text="25.0" />
            <Label style="-fx-font-size: 12px;" text="Rango normal: 18.5 - 24.9" />
        </VBox>
        
        <!-- Botón Volver -->
        <Button styleClass="button-primary" text="← Volver a la lista" />

    </VBox>
</VBox>