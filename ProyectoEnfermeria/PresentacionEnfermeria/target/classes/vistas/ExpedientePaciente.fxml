<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="800.0" prefWidth="900.0" spacing="20.0" styleClass="root" 
      stylesheets="@ExpedientePaciente.css" xmlns="http://javafx.com/javafx/17" fx:controller="controladores.ExpedientePacienteController"
      xmlns:fx="http://javafx.com/fxml/1">
    
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <!-- Encabezado Principal -->
    <VBox spacing="5.0">
        <Label styleClass="title-label" text="Historial Medico del Paciente" />
        <Label styleClass="subtitle-label" text="Registro clínicos completos y gestion de informacion de salud" />
    </VBox>

    
    <!-- Tarjeta de Información Personal -->
    <VBox spacing="15.0" styleClass="section-container">
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label style="-fx-font-size: 30px;" text="👤" />
            <Label fx:id="lblNombre" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Mario Alfredo Jimenez Valencia" />
        </HBox>
        <HBox spacing="50.0">
            <Label fx:id="lblTelefono" text="ID: EMP-4245" />
            <Label fx:id="lblDepartamento" text="Departamento: Manufactura" />
            <Label fx:id="lblEdad" text="Edad: 34" />
            <Label fx:id="lblTipoSangre" text="Tipo de Sangre: A-" />
        </HBox>
    </VBox>

    <!-- Barra de Navegación -->
    <HBox alignment="CENTER" spacing="20.0" styleClass="tab-container">
        <Button prefWidth="150" styleClass="nav-button-active" text="Signos Vitales" />
        <Button prefWidth="150" styleClass="nav-button" text="Antecedentes Medicos" />
        <Button prefWidth="150" styleClass="nav-button" text="Sintomas y Diagnostico" />
        <Button prefWidth="150" styleClass="nav-button" text="Plan de Tratamiento" />
    </HBox>
    
    <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">
        <!-- Aquí se cargarán los otros FXMLs -->
    </StackPane>
    
    <!-- Botón Volver -->
    <Button styleClass="button-primary" text="← Volver a la lista" />
</VBox>