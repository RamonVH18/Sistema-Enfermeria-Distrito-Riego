<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox id="citas-container" fx:id="citasMainContainer" alignment="CENTER" spacing="20.0" stylesheets="@../styles/style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="controladores.CitasController">
    <padding>
        <Insets bottom="40.0" left="20.0" right="20.0" top="20.0" />
    </padding>
            
    <VBox fx:id="calendarCard" alignment="TOP_CENTER" prefWidth="300.0" styleClass="calendar-card" HBox.hgrow="NEVER">
        <Label fx:id="lblMesAño" styleClass="calendar-month-title" text="May 2026">
            <VBox.margin>
                <Insets bottom="10.0" top="10.0" />
            </VBox.margin>
        </Label>
                
        <DatePicker fx:id="datePicker" editable="false" showWeekNumbers="false" styleClass="calendar-control" VBox.vgrow="ALWAYS" />
    </VBox>
            
    <VBox fx:id="agendaCard" prefWidth="400.0" spacing="10.0" styleClass="agenda-card" HBox.hgrow="NEVER">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>

        <Label fx:id="lblFechaSeleccionada" styleClass="agenda-date-title" text="18 de Mayo del 2026">
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>
                
        <ListView fx:id="lvCitasDelDia" styleClass="agenda-list" VBox.vgrow="ALWAYS" />
                
        <HBox alignment="CENTER" styleClass="agenda-footer">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
            <Button fx:id="btnNuevaCita" mnemonicParsing="false" onAction="#handleNuevaCita" styleClass="new-cita-button" text="+ Nueva Cita" />
        </HBox>
    </VBox> 
</HBox>
