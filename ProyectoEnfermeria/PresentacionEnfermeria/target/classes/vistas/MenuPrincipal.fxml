<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox fx:id="root" prefHeight="768.0" prefWidth="1024.0" styleClass="main-root" stylesheets="@../styles/menuprincipal.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controladores.MenuPrincipalController">
    
    <VBox fx:id="sidePanel" alignment="TOP_CENTER" prefWidth="200.0" spacing="20.0" styleClass="side-panel">
        
        <VBox alignment="CENTER" spacing="5.0" styleClass="side-panel-header">
            <VBox.margin>
                <Insets bottom="30.0" top="10.0" />
            </VBox.margin>
         <FlowPane id="imagen-logo-container">
            <children>
                  <ImageView id="imagen-logo" fx:id="logoImageView" fitWidth="100.0" preserveRatio="true">
                      <image>
                          <Image url="@../images/logo.png" />
                      </image>
                  </ImageView>
            </children>
         </FlowPane>
            <Label alignment="CENTER" styleClass="imagen-descripcion" text="Distrito de Riego del Rio Yaqui" textFill="WHITE" wrapText="true">
                <font>
                    <Font name="System Bold" size="12.0" />
                </font>
            </Label>
            <Label alignment="CENTER" styleClass="imagen-descripcion" text="Sistema de Enfermeria" wrapText="true" />
        </VBox>
        
        <Button fx:id="btnPanelPrincipal" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarPanelPrincipal" styleClass="menu-button" text="Panel Principal" />
        <Button fx:id="btnCitas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarCitas" styleClass="menu-button" text="Citas" />
        <Button fx:id="btnHistorialPacientes" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction ="#mostrarHistorial" styleClass="menu-button" text="Historial de Pacientes" />
        <Button fx:id="btnInformesSalud" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-button" text="Informes de Salud" />
        
        <Pane fx:id="springPane" VBox.vgrow="ALWAYS" />
      <FlowPane prefHeight="150.0" prefWidth="200.0" styleClass="side-panel-footer">
         <children>
               <Label fx:id="lblNombreEnfermero" text="Enfermero" textFill="WHITE">
                   <font>
                       <Font name="System Bold" size="12.0" />
                   </font>
               </Label>
               <Button fx:id="btnInicioSesion" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="logout-button" text="Iniciar Sesión" />
         </children>
      </FlowPane>
        <HBox.margin>
            <Insets />
        </HBox.margin>
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>
    </VBox>
   <StackPane id="main-layout" fx:id="mainLayout">
      <children></children>
   </StackPane> 
</HBox>
