<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controladores.HistorialPacienteController" styleClass="main-container">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

   
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="txtBusqueda" prefHeight="40.0" prefWidth="450.0" 
                   promptText="Buscar por nombre de paciente o ID de empleado..." styleClass="search-field" />
        <Button fx:id="btnBuscar" text="Buscar" prefHeight="40.0" prefWidth="100.0" 
                styleClass="action-button" onAction="#cargarPacientes" />
    </HBox>

  
    <TableView fx:id="tablaPacientes" VBox.vgrow="ALWAYS" styleClass="patient-table">
        <columns>
            <TableColumn fx:id="colNombre" prefWidth="250.0" text="Paciente" />
            <TableColumn fx:id="colTelefono" prefWidth="120.0" text="Telefono" />
            <TableColumn fx:id="colArea" prefWidth="180.0" text="Departamento" />
            <TableColumn fx:id="colEdad" prefWidth="80.0" text="Edad" />
            <TableColumn fx:id="colSangre" prefWidth="120.0" text="Tipo de Sangre" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- Botón de acción inferior -->
    <HBox alignment="CENTER_RIGHT">
        <Button text="Ver Expediente Clínico" prefHeight="40.0" prefWidth="200.0"
                onAction="#btnVerExpedienteAction" styleClass="view-button" />
    </HBox>
</VBox>