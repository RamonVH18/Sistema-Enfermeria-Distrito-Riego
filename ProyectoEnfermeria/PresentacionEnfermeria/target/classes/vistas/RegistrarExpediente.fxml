<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controladores.RegistrarExpedienteController" 
      style="-fx-background-color: #F8F9FA;" spacing="15.0">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <VBox HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Registro de Antecedentes Clínicos" />
            <Label style="-fx-text-fill: #7F8C8D;" text="Gestión de historial médico ocupacional del personal" />
        </VBox>
    </HBox>

    <Separator />

    <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        <tabs>
            <Tab text="Antecedentes">
                <content>
                    <fx:include source="/components/RegistroAntecedentes.fxml" />
                </content>
            </Tab>

            <Tab text="Exploración Física">
                <content>
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                        <VBox fx:id="contenedorExploracion" spacing="20" style="-fx-padding: 20;">
                        </VBox>
                    </ScrollPane>
                </content>
            </Tab>
        </tabs>
    </TabPane>

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button text="Cancelar" style="-fx-text-fill: #7F8C8D;" />
        <Button fx:id="btnGuardarExpediente" text="Guardar Expediente" onAction="#guardarExpediente" 
                style="-fx-background-color: #2C3E50; -fx-text-fill: white; -fx-font-weight: bold;" 
                prefHeight="40.0" prefWidth="200.0" />
    </HBox>
</VBox>
