<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="5" style="-fx-padding: 10; -fx-background-color: white;">
    <Label fx:id="lblTitulo" style="-fx-font-weight: bold;" />
    <TableView fx:id="tblAtributos" prefHeight="150">
        <columns>
            <TableColumn fx:id="colAspecto" text="Atributo" prefWidth="150" />
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="120" />
            <TableColumn fx:id="colNota" text="Nota" prefWidth="300" />
        </columns>
    </TableView>
</VBox>