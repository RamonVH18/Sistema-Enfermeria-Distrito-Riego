<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="formContainer" prefWidth="500" spacing="15" styleClass="form-card" stylesheets="@../styles/AgendarCita.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controladores.AgendarCitaController">
    <padding>
        <Insets bottom="30" left="40" right="40" top="30" />
    </padding>

    <Label alignment="CENTER" maxWidth="Infinity" styleClass="form-title" text="Agendar Nueva Cita" />

    <VBox spacing="5">
        <Label styleClass="form-label" text="Nombre del Paciente" />
        <ComboBox id="nombre-paciente" fx:id="cbPaciente" editable="true" maxWidth="Infinity" />
    </VBox>

    <VBox spacing="5">
        <Label styleClass="form-label" text="Fecha" />
        <DatePicker id="fecha-picker" fx:id="dpFechaCita" maxWidth="Infinity" />
    </VBox>

    <VBox spacing="5">
        <Label styleClass="form-label" text="Hora" />
        <ComboBox id="hora-picker" fx:id="cbHora" maxWidth="Infinity" promptText="Seleccione hora" />
    </VBox>

    <VBox spacing="5">
        <Label styleClass="form-label" text="Descripción de la cita" />
        <TextArea fx:id="txtDescripcion" prefHeight="100" promptText="ej. Chequeo Rutinario" wrapText="true">
            <font>
                <Font size="14.0" />
            </font>
        </TextArea>
    </VBox>

    <HBox alignment="CENTER" spacing="20">
        <Button fx:id="btnCancelar" onAction="#cancelar" styleClass="btn-cancel" text="Cancelar">
            <cursor>
                <Cursor fx:constant="HAND" />
            </cursor>
        </Button>
        <Button fx:id="btnAgendar" onAction="#guardarCita" styleClass="btn-submit" text="Agendar Cita">
            <cursor>
                <Cursor fx:constant="HAND" />
            </cursor>
        </Button>
    </HBox>
</VBox>
