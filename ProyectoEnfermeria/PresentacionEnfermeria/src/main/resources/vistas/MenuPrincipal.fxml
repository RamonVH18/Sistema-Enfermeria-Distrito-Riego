<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox fx:id="root" prefHeight="768.0" prefWidth="1024.0" styleClass="main-root" stylesheets="@../styles/menuprincipal.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controladores.MenuPrincipalController">
    
    <VBox fx:id="sidePanel" alignment="TOP_CENTER" prefWidth="200.0" spacing="20.0" styleClass="side-panel">
        
        <VBox alignment="CENTER" spacing="5.0" styleClass="side-panel-header">
            <VBox.margin>
                <Insets bottom="30.0" top="10.0" />
            </VBox.margin>
         <FlowPane id="imagen-logo-container">
            <children>
                  <ImageView id="imagen-logo" fx:id="logoImageView" fitWidth="100.0" preserveRatio="true">
                      <image>
                          <Image url="@../images/logo.png" />
                      </image>
                  </ImageView>
            </children>
         </FlowPane>
            <Label alignment="CENTER" styleClass="imagen-descripcion" text="Distrito de Riego del Rio Yaqui" textFill="WHITE" wrapText="true">
                <font>
                    <Font name="System Bold" size="12.0" />
                </font>
            </Label>
            <Label alignment="CENTER" styleClass="imagen-descripcion" text="Sistema de Enfermeria" wrapText="true" />
        </VBox>
        
        <Button fx:id="btnPanelPrincipal" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarPanelPrincipal" styleClass="menu-button" text="Panel Principal" />
        <Button fx:id="btnCitas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarCitas" styleClass="menu-button" text="Citas" />
        <Button fx:id="btnHistorialPacientes" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-button" text="Historial de Pacientes" />
        <Button fx:id="btnInformesSalud" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-button" text="Informes de Salud" />
        
        <Pane fx:id="springPane" VBox.vgrow="ALWAYS" />
      <FlowPane prefHeight="150.0" prefWidth="200.0" styleClass="side-panel-footer">
         <children>
               <Label fx:id="lblNombreEnfermero" text="Enfermero" textFill="WHITE">
                   <font>
                       <Font name="System Bold" size="12.0" />
                   </font>
               </Label>
               <Button fx:id="btnInicioSesion" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="logout-button" text="Iniciar Sesión" />
         </children>
      </FlowPane>
        <HBox.margin>
            <Insets />
        </HBox.margin>
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>
    </VBox>
   <StackPane id="main-layout" fx:id="mainLayout" prefHeight="768.0" prefWidth="826.0">
      <children>
         <VBox id="panel-principal" fx:id="panelDerecho" prefHeight="768.0" prefWidth="836.0" spacing="20.0">
            <children>
               <GridPane id="datos-container" prefHeight="70.0" prefWidth="810.0">
                 <columnConstraints>
                   <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                   <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                     <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                     <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                 </columnConstraints>
                 <rowConstraints>
                   <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                 </rowConstraints>
                  <children>
                     <VBox styleClass="stat-card">
                        <children>
                           <Label styleClass="stat-card-title" text="Pacientes Activos" />
                           <Label fx:id="pacientesActivosLabel" styleClass="stat-card-number" text="0" />
                        </children>
                     </VBox>
                     <VBox styleClass="stat-card" GridPane.columnIndex="1">
                        <children>
                           <Label styleClass="stat-card-title" text="Citas de Hoy:" />
                           <Label fx:id="citasHoyLabel" styleClass="stat-card-number" text="0" />
                        </children>
                     </VBox>
                     <VBox styleClass="stat-card" GridPane.columnIndex="2">
                        <children>
                           <Label styleClass="stat-card-title" text="Revisiones Pendientes:" />
                           <Label fx:id="revisionesPendientesLabel" styleClass="stat-card-number" text="0" />
                        </children>
                     </VBox>
                     <VBox prefHeight="70.0" prefWidth="229.0" styleClass="stat-card" GridPane.columnIndex="3">
                        <children>
                           <Label styleClass="stat-card-title" text="Tiempo de espera apróx:" />
                           <Label fx:id="tiempoEsperaAproxLabel" styleClass="stat-card-number" text="15 minutos" />
                        </children>
                     </VBox>
                  </children>
               </GridPane>
               <VBox id="resumen-citas-container" fx:id="listaCitas" prefHeight="200.0" prefWidth="100.0">
                  <children>
                     <FlowPane id="descripcion-citas-container" prefHeight="0.0" prefWidth="200.0">
                        <children>
                           <Label styleClass="descripcion-cita" text="Citas de Hoy:" />
                           <Label layoutX="20.0" layoutY="30.0" text="0" />
                           <Label styleClass="descripcion-cita" text="Programadas:" />
                           <Label layoutX="137.0" layoutY="30.0" text="0" />
                        </children>
                     </FlowPane>
                     <ScrollPane prefHeight="200.0" prefWidth="200.0">
                        <content>
                           <VBox prefHeight="200.0" prefWidth="100.0">
                              <children>
                                 <HBox prefHeight="100.0" prefWidth="200.0" spacing="240.0">
                                    <children>
                                       <Label text="Hora:">
                                          <padding>
                                             <Insets top="10.0" />
                                          </padding>
                                       </Label>
                                       <VBox prefHeight="200.0" prefWidth="100.0" />
                                       <Label text="Label" />
                                       <Button mnemonicParsing="false" text="Ver Detalles" />
                                    </children>
                                 </HBox>
                                 <HBox prefHeight="100.0" prefWidth="200.0" />
                                 <HBox prefHeight="100.0" prefWidth="200.0" />
                              </children>
                           </VBox>
                        </content>
                        <padding>
                           <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                     </ScrollPane>
                  </children>
               </VBox>
            </children>
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
         </VBox>
      </children>
   </StackPane> 
</HBox>
