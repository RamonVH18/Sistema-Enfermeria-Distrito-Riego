<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controladores.ExpedientePacienteController">
    <VBox spacing="15.0" styleClass="expediente-container">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
        </padding>

        <Label text="EXPEDIENTE CLÍNICO - DISTRITO DE RIEGO" styleClass="header-label" />
        <Separator />

        <TitledPane text="1. Datos de Identificación" collapsible="false">
            <GridPane hgap="10.0" vgap="10.0">
                <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="lblNombre" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>
                
                <Label text="Género:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="lblGenero" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Fecha Nac.:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="lblFechaNac" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <Label text="Área:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="lblArea" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Grupo Sanguíneo:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <TextField fx:id="lblSangre" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="2" />
            </GridPane>
        </TitledPane>

        <TitledPane text="2. Antecedentes Laborales" collapsible="false">
            <VBox spacing="10.0">
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label text="Inicio de Labores:" />
                    <DatePicker fx:id="dpInicioLabores" disable="true" />
                </HBox>
                <Label text="Exposición a agentes:" style="-fx-font-weight: bold;" />
                <FlowPane hgap="20.0" vgap="10.0">
                    <CheckBox text="Disolventes" fx:id="chkDisolventes" disable="true" />
                    <CheckBox text="Ruido" fx:id="chkRuido" disable="true" />
                    <CheckBox text="Polvos" fx:id="chkPolvos" disable="true" />
                    <CheckBox text="Biológicos" fx:id="chkBiologicos" disable="true" />
                </FlowPane>
            </VBox>
        </TitledPane>

        <TitledPane text="3. Signos Vitales y Exploración Física" collapsible="false">
            <GridPane hgap="10.0" vgap="10.0">
                <Label text="Presión Arterial:" />
                <TextField fx:id="txtPA" GridPane.columnIndex="1" />
                
                <Label text="Frec. Cardiaca:" GridPane.columnIndex="2" />
                <TextField fx:id="txtFC" GridPane.columnIndex="3" />

                <Label text="Temperatura:" GridPane.rowIndex="1" />
                <TextField fx:id="txtTemp" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Peso (kg):" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="txtPeso" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            </GridPane>
        </TitledPane>

        <TitledPane text="4. Nota de Evolución y Tratamiento" collapsible="false">
            <TextArea fx:id="txtNotas" prefHeight="150.0" wrapText="true" 
                      promptText="Escriba aquí el diagnóstico y plan de tratamiento..." />
        </TitledPane>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Imprimir PDF" styleClass="secondary-button" />
            <Button text="Guardar Cambios" styleClass="primary-button" />
        </HBox>
    </VBox>
</ScrollPane>