<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.1">
    <persistence-unit name="SistemaDistritoRiegoPU">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>modelo.Cita</class>
        <class>modelo.Empleado</class>
        <class>modelo.Enfermero</class>
        <class>modelo.Serie</class>
        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/SistemaDistritoRiego"/>
            <property name="jakarta.persistence.jdbc.user" value="adminDR"/>
            <property name="jakarta.persistence.jdbc.password" value="Leonardo123"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>

